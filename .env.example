# mtzHRF — Variáveis de ambiente
# Copie para .env e preencha os valores reais
# O arquivo .env NÃO é commitado (ver .gitignore)

# ── Twilio (SMS de emergência) ─────────────────────────────────────────────────
# Crie conta em https://twilio.com, pegue as credenciais no Console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+14155551234   # número Twilio verificado (formato E.164)
